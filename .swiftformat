# ignore vendor files, will be removed in the future
--exclude WireGuardMultiTunnelHelper/SKQueue.swift,WireGuardMultiTunnel/INIParser.swift

# keep the opening brace on the same line as a multiline condition/signature so
# it does not conflict with tailor's brace-style rule (no line break before brace)
--disable wrapMultilineStatementBraces
